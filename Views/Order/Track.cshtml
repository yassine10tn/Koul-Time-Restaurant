@model RestaurantApp.ViewModels.OrderTrackingViewModel
@{
    ViewData["Title"] = "Suivi commande #" + Model.Order.Id;
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="fw-bold mb-0">Commande #@Model.Order.Id</h3>
                    <span class="badge bg-@Model.Order.StatusColor fs-6">
                        @Model.Order.StatusLabel
                    </span>
                </div>

                <!-- Stepper -->
                <div class="d-flex justify-content-between mb-4 position-relative">
                    <div class="position-absolute top-50 start-0 end-0"
                         style="height:3px; background:#dee2e6; z-index:0; transform:translateY(-50%)"></div>
                    @foreach (var step in Model.Steps)
                    {
                        var done = Model.IsStepDone(step.Status);
                        <div class="text-center position-relative" style="z-index:1; flex:1">
                            <div class="mx-auto rounded-circle d-flex align-items-center justify-content-center fw-bold"
                                 style="width:44px; height:44px; font-size:1.2rem;
                                background:@(done ? "#ffc107" : "#dee2e6");
                                border: 3px solid @(done ? "#ffc107" : "#dee2e6")">
                                @step.Icon
                            </div>
                            <small class="d-block mt-1 @(done ? "fw-bold" : "text-muted")">
                                @step.Label
                            </small>
                        </div>
                    }
                </div>

                <!-- Détails -->
                <div class="row mt-4">
                    <div class="col-md-6">
                        <h6 class="fw-bold">Informations client</h6>
                        <p class="mb-1"><i class="bi bi-person"></i> @Model.Order.CustomerName</p>
                        <p class="mb-1"><i class="bi bi-telephone"></i> @Model.Order.CustomerPhone</p>
                        @if (Model.Order.DeliveryType == RestaurantApp.Models.DeliveryType.Livraison)
                        {
                            <p class="mb-1"><i class="bi bi-geo-alt"></i> @Model.Order.CustomerAddress</p>
                        }
                        else
                        {
                            <p class="mb-1"><i class="bi bi-shop"></i> Pickup en restaurant</p>
                        }
                    </div>
                    <div class="col-md-6">
                        <h6 class="fw-bold">Détail de la commande</h6>
                        @foreach (var item in Model.Order.Items)
                        {
                            <div class="d-flex justify-content-between">
                                <span>@item.Name × @item.Quantity</span>
                                <span>@item.Subtotal.ToString("F2") €</span>
                            </div>
                        }
                        <hr />
                        <div class="d-flex justify-content-between fw-bold">
                            <span>Total</span>
                            <span class="text-success">@Model.Order.Total.ToString("F2") €</span>
                        </div>
                    </div>
                </div>

                <div class="mt-4 d-flex gap-2">
                    <a asp-action="History" class="btn btn-outline-dark">
                        <i class="bi bi-list"></i> Mes commandes
                    </a>
                    <a asp-controller="Menu" asp-action="Index" class="btn btn-warning">
                        <i class="bi bi-plus"></i> Nouvelle commande
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>