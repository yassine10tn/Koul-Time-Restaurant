@model RestaurantApp.Models.Cart
@{
    ViewData["Title"] = "Mon Panier";
}

<h2 class="fw-bold mb-4">🛒 Mon Panier</h2>

@if (!Model.Items.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-cart-x" style="font-size:4rem; color:#ccc"></i>
        <h4 class="text-muted mt-3">Votre panier est vide</h4>
        <a asp-controller="Menu" asp-action="Index" class="btn btn-dark mt-3">
            Voir le menu
        </a>
    </div>
}
else
{
    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-body">
                    <table class="table align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>Plat</th>
                                <th>Prix</th>
                                <th>Quantité</th>
                                <th>Total</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td class="fw-semibold">@item.Name</td>
                                    <td>@item.Price.ToString("F3") DT</td>
                                    <td>
                                        <form asp-action="UpdateQuantity" method="post" class="d-flex align-items-center gap-1">
                                            <input type="hidden" name="menuItemId" value="@item.MenuItemId" />
                                            <input type="number" name="quantity" value="@item.Quantity"
                                                   min="1" max="10" class="form-control form-control-sm"
                                                   style="width:65px"
                                                   onchange="this.form.submit()" />
                                        </form>
                                    </td>
                                    <td class="fw-bold text-success">@item.Total.ToString("F3") DT</td>
                                    <td>
                                        <form asp-action="Remove" method="post">
                                            <input type="hidden" name="menuItemId" value="@item.MenuItemId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <form asp-action="Clear" method="post" class="mt-2">
                <button type="submit" class="btn btn-outline-danger btn-sm"
                        onclick="return confirm('Vider le panier ?')">
                    <i class="bi bi-trash"></i> Vider le panier
                </button>
            </form>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title fw-bold">Récapitulatif</h5>
                    <hr />
                    <div class="d-flex justify-content-between mb-2">
                        <span>Articles (@Model.ItemCount)</span>
                        <span>@Model.Total.ToString("F3") DT</span>
                    </div>
                    <div class="d-flex justify-content-between fw-bold fs-5 border-top pt-2">
                        <span>Total</span>
                        <span class="text-success">@Model.Total.ToString("F3") DT</span>
                    </div>
                    <a asp-action="Checkout" class="btn btn-warning w-100 mt-3 fw-bold">
                        <i class="bi bi-credit-card"></i> Commander
                    </a>
                    <a asp-controller="Menu" asp-action="Index" class="btn btn-outline-dark w-100 mt-2">
                        Continuer mes achats
                    </a>
                </div>
            </div>
        </div>
    </div>
}