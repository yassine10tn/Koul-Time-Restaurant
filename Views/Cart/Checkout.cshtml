@model RestaurantApp.ViewModels.CheckoutViewModel
@{
    ViewData["Title"] = "Finaliser la commande";
}

<h2 class="fw-bold mb-4">📋 Finaliser la commande</h2>

<div class="row">
    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">Vos informations</h5>
                <form asp-controller="Order" asp-action="PlaceOrder" method="post">
                    <div class="mb-3">
                        <label asp-for="CustomerName" class="form-label fw-semibold"></label>
                        <input asp-for="CustomerName" class="form-control"
                               placeholder="Ex: Mohamed Ben Ali" />
                        <span asp-validation-for="CustomerName" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="CustomerPhone" class="form-label fw-semibold"></label>
                        <input asp-for="CustomerPhone" class="form-control"
                               placeholder="Ex: 55 123 456" />
                        <span asp-validation-for="CustomerPhone" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="CustomerEmail" class="form-label fw-semibold"></label>
                        <input asp-for="CustomerEmail" class="form-control"
                               placeholder="Ex: mohamed@gmail.com" />
                        <span asp-validation-for="CustomerEmail" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Mode de réception</label>
                        <div class="d-flex gap-3">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" asp-for="DeliveryType"
                                       value="0" id="livraison" checked />
                                <label class="form-check-label" for="livraison">🚴 Livraison</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" asp-for="DeliveryType"
                                       value="1" id="pickup" />
                                <label class="form-check-label" for="pickup">🏪 Pickup</label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3" id="addressField">
                        <label asp-for="CustomerAddress" class="form-label fw-semibold"></label>
                        <input asp-for="CustomerAddress" class="form-control"
                               placeholder="Ex: Rue de la République, Tunis 1000" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Notes" class="form-label fw-semibold"></label>
                        <textarea asp-for="Notes" class="form-control" rows="2"
                                  placeholder="Ex: Allergie, étage, interphone..."></textarea>
                    </div>

                    <button type="submit" class="btn btn-warning w-100 fw-bold py-2">
                        <i class="bi bi-check-circle"></i> Confirmer la commande
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="fw-bold">Votre commande</h5>
                <hr />
                @foreach (var item in Model.Cart.Items)
                {
                    <div class="d-flex justify-content-between mb-1">
                        <span>@item.Name × @item.Quantity</span>
                        <span class="fw-semibold">@item.Total.ToString("F3") DT</span>
                    </div>
                }
                <hr />
                <div class="d-flex justify-content-between fw-bold fs-5">
                    <span>Total</span>
                    <span class="text-success">@Model.Cart.Total.ToString("F3") DT</span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const radios = document.querySelectorAll('input[name="DeliveryType"]');
        const addressField = document.getElementById('addressField');

        // Initialisation au chargement
        const selected = document.querySelector('input[name="DeliveryType"]:checked');
        if (selected) {
            addressField.style.display = selected.value === '0' ? 'block' : 'none';
        }

        // Changement dynamique
        radios.forEach(r => r.addEventListener('change', () => {
            addressField.style.display = r.value === '0' ? 'block' : 'none';
        }));
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}