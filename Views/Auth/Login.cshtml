@model RestaurantApp.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Connexion";
    Layout = "_Layout";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card shadow-lg border-0">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <span style="font-size:3rem">🍽️</span>
                    <h3 class="fw-bold mt-2">Connexion</h3>
                    <p class="text-muted small">Accédez à votre compte</p>
                </div>

                <form asp-action="Login" method="post">
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                            <input asp-for="Email" class="form-control" placeholder="email@exemple.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Password" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock"></i></span>
                            <input asp-for="Password" class="form-control" placeholder="••••••••" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey(""))
                    {
                        <div class="alert alert-danger py-2">
                            <i class="bi bi-exclamation-circle"></i>
                            Email ou mot de passe incorrect
                        </div>
                    }

                    <button type="submit" class="btn btn-warning w-100 fw-bold py-2">
                        <i class="bi bi-box-arrow-in-right"></i> Se connecter
                    </button>
                </form>

                <hr class="my-4" />

                <div class="text-center">
                    <p class="text-muted small mb-2">Pas encore de compte ?</p>
                    <a asp-action="Register" class="btn btn-outline-dark w-100">
                        <i class="bi bi-person-plus"></i> Créer un compte
                    </a>
                </div>

            
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}