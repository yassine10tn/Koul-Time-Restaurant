    @model RestaurantApp.Models.MenuItem
    @{
        ViewData["Title"] = Model.Name;
    }

    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-body p-4">
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-3">
                        <i class="bi bi-arrow-left"></i> Retour au menu
                    </a>
                    <h2 class="fw-bold">@Model.Name</h2>
                    <p class="text-muted">@Model.Description</p>
                <p class="fs-3 fw-bold text-success">@Model.Price.ToString("F3") DT</p>
                    <form asp-controller="Cart" asp-action="Add" method="post">
                        <input type="hidden" name="menuItemId" value="@Model.Id" />
                        <div class="d-flex align-items-center gap-3 mt-3">
                            <label class="fw-semibold">Quantité :</label>
                            <input type="number" name="quantity" value="1" min="1" max="10"
                                   class="form-control" style="width:80px" />
                            <button type="submit" class="btn btn-warning px-4">
                                <i class="bi bi-cart-plus"></i> Ajouter au panier
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>