@model RestaurantApp.ViewModels.MenuViewModel
@{
    ViewData["Title"] = "Notre Menu";
}

<div class="row mb-4">
    <div class="col">
        <h1 class="fw-bold">🍽️ Notre Menu</h1>
    </div>
</div>

<!-- Recherche -->
<form asp-action="Index" method="get" class="row g-2 mb-4">
    <div class="col-md-6">
        <input type="text" name="search" value="@Model.SearchQuery"
               class="form-control" placeholder="Rechercher un plat..." />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-dark">
            <i class="bi bi-search"></i> Rechercher
        </button>
    </div>
    @if (!string.IsNullOrEmpty(Model.SearchQuery))
    {
        <div class="col-auto">
            <a asp-action="Index" class="btn btn-outline-secondary">Effacer</a>
        </div>
    }
</form>

<!-- Catégories -->
<div class="d-flex flex-wrap gap-2 mb-4">
    <a asp-action="Index" class="btn @(Model.SelectedCategoryId == null ? "btn-dark" : "btn-outline-dark")">
        Tout voir
    </a>
    @foreach (var cat in Model.Categories)
    {
        <a asp-action="Index" asp-route-categoryId="@cat.Id"
           class="btn @(Model.SelectedCategoryId == cat.Id ? "btn-dark" : "btn-outline-dark")">
            @cat.Icon @cat.Name
        </a>
    }
</div>

<!-- Plats -->
@if (!Model.Items.Any())
{
    <div class="text-center py-5">
        <h4 class="text-muted">Aucun plat trouvé</h4>
        <a asp-action="Index" class="btn btn-dark mt-2">Voir tout le menu</a>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var item in Model.Items)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">@item.Name</h5>
                        <p class="card-text text-muted small">@item.Description</p>
                        <p class="card-text fs-5 fw-bold text-success">@item.Price.ToString("F3") DT</p>
                    </div>
                    <div class="card-footer bg-transparent d-flex justify-content-between align-items-center">
                        <a asp-action="Detail" asp-route-id="@item.Id"
                           class="btn btn-sm btn-outline-dark">
                            <i class="bi bi-eye"></i> Détail
                        </a>
                        <form asp-controller="Cart" asp-action="Add" method="post" class="d-inline">
                            <input type="hidden" name="menuItemId" value="@item.Id" />
                            <input type="hidden" name="quantity" value="1" />
                            <button type="submit" class="btn btn-sm btn-warning">
                                <i class="bi bi-cart-plus"></i> Ajouter
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}